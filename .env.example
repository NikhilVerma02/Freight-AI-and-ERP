# LLM Gateway (OpenAI-compatible / LiteLLM-style proxy)
API_ENDPOINT=https://your-gateway-endpoint.example.com/v1
API_KEY=your-api-key-here

# ERP App (MCP Server)
ERP_HOST=127.0.0.1
ERP_PORT=8001
ERP_MCP_URL=http://127.0.0.1:8001/mcp

# AI App (MCP Client)
AI_HOST=127.0.0.1
AI_PORT=8002

# Auth
SESSION_SECRET=change-me-in-production

# SLA RAG (ERP vendor SLA Q&A) — Gemini embeddings + Groq chat, both free-tier
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GROQ_API_KEY=your-groq-api-key-here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
SLA_RAG_CHUNK_SIZE=800
SLA_RAG_CHUNK_OVERLAP=100
SLA_RAG_TOP_K=4

# Observability/Tracing — Langfuse Cloud free tier (https://cloud.langfuse.com)
# Sign up free, create a project, paste its keys here. Leave blank to disable
# tracing entirely (every call site no-ops gracefully without these).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
